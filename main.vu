import re

def extract_alert_details(ticket_text):
    # First try regex pattern matching
    url_pattern = r'(https?://\S+)'
    urls = re.findall(url_pattern, ticket_text)
    
    # If no URL found, use AI extraction
    if not urls:
        response = openai.ChatCompletion.create(
            model="gpt-4",
            messages=[
                {"role": "system", "content": "Extract website URLs from this ticket. Respond with ONLY the URL."},
                {"role": "user", "content": ticket_text}
            ]
        )
        urls = [response.choices[0].message['content'].strip()]
    
    return {
        "website_url": urls[0],
        "error_type": re.findall(r'\b(5\d{2}|4\d{2}|timeout|down)\b', ticket_text, re.I),
        "reported_source": "zendesk" if "via MonitoringSystem" in ticket_text else "user"
    }
