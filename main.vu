import openai

def categorize_ticket(ticket_text):
    response = openai.ChatCompletion.create(
        model="gpt-4",
        messages=[
            {
                "role": "system",
                "content": f"""
                Classify this support ticket into ONE of these categories:
                {', '.join(categories)}.
                Return ONLY the category name, nothing else.
                """
            },
            {
                "role": "user",
                "content": ticket_text
            }
        ],
        temperature=0  # For deterministic output
    )
    
    return response.choices[0].message['content'].strip()

# Example usage
ticket = "My payment failed when I tried to upgrade my plan."
print(categorize_ticket(ticket))  # Output: "Billing/Payments"



rules = {
  "Billing": ["payment", "invoice", "refund"],
  "Outage": ["down", "outage", "503 error"]
}

def rule_based_classifier(text):
  for cat, keywords in rules.items():
      if any(kw in text.lower() for kw in keywords):
          return cat
  return None

