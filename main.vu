import openai
import tiktoken  # For token counting
from datetime import datetime, timedelta

class DebuggingAssistant:
    def __init__(self, openai_api_key):
        openai.api_key = openai_api_key
        self.encoder = tiktoken.get_encoding("cl100k_base")  # GPT-4 tokenizer
        self.summary_prompt = """You are a senior systems engineer. Summarize these logs by:
1. Identifying unique error types and their frequencies
2. Noting critical warnings/events
3. Highlighting temporal patterns
4. Preserving important timestamps and error codes
5. Ignoring routine informational messages

Format:
- Key Errors: [error1] (count), [error2] (count), ...
- Critical Events: [event1] @ [timestamp], ...
- Patterns: [pattern description]
- Relevant Warnings: [warning1], ..."""

    def summarize_logs(self, logs, max_summary_tokens=1000):
        """Reduce log size while preserving key information"""
        try:
            # First-stage summary with cheaper model
            response = openai.ChatCompletion.create(
                model="gpt-3.5-turbo",
                messages=[
                    {"role": "system", "content": self.summary_prompt},
                    {"role": "user", "content": logs}
                ],
                temperature=0.1,
                max_tokens=max_summary_tokens
            )
            summary = response.choices[0].message['content']
            
            # Enforce token limit strictly
            token_count = len(self.encoder.encode(summary))
            if token_count > max_summary_tokens:
                summary = self._truncate_text(summary, max_summary_tokens)
            
            return summary
        except Exception as e:
            print(f"Summarization failed: {str(e)}")
            return self._fallback_summary(logs, max_summary_tokens)

    def _truncate_text(self, text, max_tokens):
        """Smart truncation preserving key sections"""
        tokens = self.encoder.encode(text)
        if len(tokens) <= max_tokens:
            return text
            
        # Prioritize keeping error-related information
        important_keywords = ['error', 'critical', 'failed', 'exception']
        sentences = text.split('\n')
        
        # Score sentences by importance
        scored_sentences = []
        for sentence in sentences:
            score = sum(1 for kw in important_keywords if kw in sentence.lower())
            scored_sentences.append((sentence, score))
        
        # Sort by importance and rebuild summary
        scored_sentences.sort(key=lambda x: x[1], reverse=True)
        truncated = []
        token_count = 0
        
        for sentence, _ in scored_sentences:
            sentence_tokens = len(self.encoder.encode(sentence))
            if token_count + sentence_tokens <= max_tokens:
                truncated.append(sentence)
                token_count += sentence_tokens
            else:
                break
                
        return '\n'.join(truncated)

    def _fallback_summary(self, logs, max_tokens):
        """Rule-based fallback when AI summarization fails"""
        # Simple error counting as backup
        error_counts = {}
        warnings = []
        
        for line in logs.split('\n'):
            if 'ERROR' in line:
                error_type = line.split('ERROR')[-1].split(':')[0].strip()
                error_counts[error_type] = error_counts.get(error_type, 0) + 1
            elif 'WARNING' in line:
                warnings.append(line.strip())
        
        summary = "Key Errors:\n"
        summary += '\n'.join([f"- {k} ({v} occurrences)" for k, v in error_counts.items()])
        summary += "\n\nRelevant Warnings:\n" + '\n'.join(warnings[:5])
        return self._truncate_text(summary, max_tokens)

    def analyze_logs(self, user_report, logs):
        """Use summarized logs for final analysis"""
        # First summarize the logs
        summary = self.summarize_logs(logs)
        
        # Calculate token savings
        orig_tokens = len(self.encoder.encode(logs))
        summ_tokens = len(self.encoder.encode(summary))
        print(f"Token reduction: {orig_tokens} → {summ_tokens} ({(1 - summ_tokens/orig_tokens)*100:.1f}% reduction)")
        
        try:
            response = openai.ChatCompletion.create(
                model="gpt-4",
                messages=[
                    {"role": "system", "content": self.system_prompt},
                    {"role": "user", "content": f"""
                    User Report: {user_report}
                    
                    Log Summary:
                    {summary}
                    
                    Full Analysis Requested:"""}
                ],
                temperature=0.3,
                max_tokens=1000
            )
            return response.choices[0].message['content']
        except Exception as e:
            return f"Analysis failed: {str(e)}"

    def generate_report(self, issue_description):
        """Updated workflow with summarization"""
        end_time = datetime.now()
        start_time = end_time - timedelta(minutes=15)
        
        logs = self.retrieve_logs("auth-service", start_time, end_time)
        masked_logs = self._mask_sensitive_data(logs)
        
        # Use summarized logs for analysis
        analysis = self.analyze_logs(issue_description, masked_logs)
        
        return {
            "metadata": {
                "issue": issue_description,
                "log_time_window": f"{start_time.isoformat()} to {end_time.isoformat()}",
                "original_log_tokens": len(self.encoder.encode(masked_logs)),
                "summary_tokens": len(self.encoder.encode(self.summarize_logs(masked_logs)))
            },
            "analysis": analysis,
            "recommended_actions": self._extract_actions(analysis)
        }

# Example Usage
if __name__ == "__main__":
    assistant = DebuggingAssistant(openai_api_key="your-api-key")
    issue = "Users cannot log in - receiving 503 Service Unavailable errors"
    report = assistant.generate_report(issue)
    print(json.dumps(report, indent=2))
